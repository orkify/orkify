{
  "name": "@orkify/cache",
  "version": "1.0.0-beta.1",
  "private": true,
  "description": "Framework-agnostic shared cache for orkify-managed processes",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
