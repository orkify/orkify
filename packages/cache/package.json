{
  "name": "@orkify/cache",
  "version": "1.0.0-beta.8",
  "description": "Framework-agnostic shared cache for orkify-managed Node.js processes & clusters",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/orkify/orkify.git",
    "directory": "packages/cache"
  },
  "homepage": "https://orkify.com",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./primary": {
      "types": "./dist/CachePrimary.d.ts",
      "import": "./dist/CachePrimary.js",
      "default": "./dist/CachePrimary.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc"
  }
}
