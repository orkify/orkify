{
  "name": "@orkify/next",
  "version": "1.0.0-beta.11",
  "description": "Next.js integration for orkify — cache handlers and browser error tracking",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/orkify/orkify.git",
    "directory": "packages/next"
  },
  "homepage": "https://orkify.com",
  "exports": {
    "./use-cache": {
      "types": "./dist/use-cache.d.ts",
      "import": "./dist/use-cache.js",
      "default": "./dist/use-cache.js"
    },
    "./isr-cache": {
      "types": "./dist/isr-cache.d.ts",
      "import": "./dist/isr-cache.js",
      "default": "./dist/isr-cache.js"
    },
    "./error-capture": {
      "types": "./dist/error-capture.d.ts",
      "import": "./dist/error-capture.js",
      "default": "./dist/error-capture.js"
    },
    "./error-handler": {
      "types": "./dist/error-handler.d.ts",
      "import": "./dist/error-handler.js",
      "default": "./dist/error-handler.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "default": "./dist/utils.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@orkify/cache": "^1.0.0-beta.11"
  },
  "peerDependencies": {
    "react": ">=18",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
