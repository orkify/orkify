{
  "name": "@orkify/cli",
  "version": "1.0.0-beta.12",
  "description": "Modern JS process orchestration and deployment for your own infrastructure",
  "keywords": [
    "process-manager",
    "cluster",
    "socket.io",
    "sticky-sessions",
    "zero-downtime",
    "graceful-reload",
    "node",
    "daemon",
    "cli",
    "orkify"
  ],
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "main": "dist/cli/index.js",
  "exports": {
    ".": "./dist/cli/index.js"
  },
  "bin": {
    "orkify": "./bin/orkify"
  },
  "files": [
    "bin/",
    "boot/",
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc -p packages/cache/tsconfig.json && tsc -p packages/next/tsconfig.json && tsc -p packages/chat/tsconfig.json && tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "clean": "rm -rf dist coverage packages/cache/dist packages/next/dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --exclude 'tests/integration/**'",
    "test:watch": "vitest --exclude 'tests/integration/**'",
    "test:coverage": "vitest run --coverage --exclude 'tests/integration/**'",
    "test:e2e": "vitest run tests/integration",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "check": "npm run build && npm run typecheck && npm run lint && npm run knip && npm run format:check && npm run test:coverage",
    "audit": "npm audit --audit-level=moderate",
    "prepack": "npm run audit && npm run check && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "author": "orkify <ahoy@orkify.com>",
  "license": "Apache-2.0",
  "homepage": "https://orkify.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/orkify/orkify.git"
  },
  "bugs": {
    "url": "https://github.com/orkify/orkify/issues"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@orkify/cache": "^1.0.0-beta.6",
    "@orkify/next": "^1.0.0-beta.6",
    "@socket.io/cluster-adapter": "^0.3.0",
    "@socket.io/sticky": "^1.0.4",
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "cron-parser": "^5.5.0",
    "express": "^5.2.1",
    "ignore": "^7.0.5",
    "pidusage": "^3.0.2",
    "socket.io": "^4.8.3",
    "source-map-js": "^1.2.1",
    "tar-stream": "^3.1.7",
    "yaml": "^2.8.2",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pidusage": "^2.0.5",
    "@types/react": "^19.2.14",
    "@types/tar-stream": "^3.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.6.0",
    "husky": "^9.1.7",
    "knip": "^5.82.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.3.0",
    "react": "^19.2.4",
    "socket.io-client": "^4.8.3",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
